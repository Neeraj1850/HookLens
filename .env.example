# Uniswap Trading API Key (required for swap simulation)
# Free at: https://developers.uniswap.org/dashboard
VITE_UNISWAP_API_KEY=

# The Graph API Key (optional - improves pool discovery)
# Free at: https://thegraph.com/studio/
VITE_THEGRAPH_API_KEY=

# Alchemy RPC Key (optional - improves onchain fallback)
# Free at: https://dashboard.alchemy.com/
VITE_ALCHEMY_API_KEY=

# WalletConnect (optional)
VITE_WALLETCONNECT_PROJECT_ID=

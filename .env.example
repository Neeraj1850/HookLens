# Uniswap Trading API Key (required for swap simulation)
# Free at: https://developers.uniswap.org/dashboard
VITE_UNISWAP_API_KEY=

# Uniswap Trading API proxy (optional for deployed apps)
# Local dev uses Vite's /uniswap-trade-api proxy automatically.
VITE_UNISWAP_PROXY_URL=

# The Graph API Key (optional - improves pool discovery)
# Free at: https://thegraph.com/studio/
VITE_THEGRAPH_API_KEY=

# Alchemy RPC Key (optional - improves onchain fallback)
# Free at: https://dashboard.alchemy.com/
VITE_ALCHEMY_API_KEY=

# Subgraph diagnostics (optional)
# Set to true to log raw Graph endpoint, variables, counts, and sample rows.
VITE_HOOKLENS_DEBUG_SUBGRAPH=false

# Quote diagnostics (optional)
# Set to true to log Uniswap quote requests, responses, and API error bodies.
VITE_HOOKLENS_DEBUG_QUOTES=false

# WalletConnect (optional)
VITE_WALLETCONNECT_PROJECT_ID=

# Required for swap simulation. Read by the local, Docker, or Vercel proxy.
UNISWAP_API_KEY=

# Required for dashboard and pool discovery.
VITE_THEGRAPH_API_KEY=

# Optional: override the browser quote proxy path.
VITE_UNISWAP_PROXY_URL=

# Optional: override the browser Ollama proxy path.
VITE_OLLAMA_PROXY_URL=/hooklens-ollama

# Optional: where the server-side proxy can reach Ollama.
OLLAMA_HOST=http://localhost:11434

# Optional: improves onchain fallback.
VITE_ALCHEMY_API_KEY=

# Optional diagnostics.
VITE_HOOKLENS_DEBUG_SUBGRAPH=false
VITE_HOOKLENS_DEBUG_QUOTES=false
